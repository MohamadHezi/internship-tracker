{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "commonjs",
    "target": "es2022",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "sourceMap": true,

    "types": ["node"]
  },

  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ]
}